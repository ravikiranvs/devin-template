{
  "name": "devin-workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": [
    // "source=claude-code-config,target=/home/vscode/.claude,type=volume",
    // "source=claude-code-skills,target=/home/vscode/.claude-global-skills,type=volume"
  ],
  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/scripts/postCreateCommand.sh",
  "containerEnv": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // "anthropic.claude-code",
        // "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "vscode"
}